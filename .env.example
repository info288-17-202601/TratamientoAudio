POSTGRES_DB=tratamiento_audio
POSTGRES_USER=tratamiento
POSTGRES_PASSWORD=tratamiento
POSTGRES_PORT=5432

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

REDIS_PORT=6379
REDIS_QUEUE=jobs_audio

FLASK_ENV=development
APP_HOST=0.0.0.0
COLLECTOR_API_INTERNAL_PORT=4000
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-jwt
JWT_EXPIRATION_HOURS=24
AUTH_REQUIRED=false

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Nombres nuevos del dashboard de Supabase. El backend tambien los acepta.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
ROOT_CORS_ORIGINS=http://localhost,https://localhost
COLLECTOR_CORS_ORIGINS=*

# Supabase pooler. Usar siempre el host *.pooler.supabase.com, no db.<ref>.supabase.co.
ROOT_DATABASE_URL=postgresql+psycopg2://postgres.project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
COLLECTOR_DATABASE_URL=postgresql://postgres.project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
PROCESSOR_DATABASE_URL=postgresql://postgres.project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_SSLMODE=require

REDIS_URL=redis://redis:6379/0
REDIS_BLOCK_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO

COLLECTOR_FRONTEND_BASE_HREF=/collector/
NG_APP_URL_COLLECTOR_API=/collector-api
NG_APP_API_URL=
