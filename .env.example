POSTGRES_DB=tratamiento_audio
POSTGRES_USER=tratamiento
POSTGRES_PASSWORD=tratamiento
POSTGRES_PORT=5432

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

REDIS_PORT=6379
REDIS_QUEUE=jobs_audio

FLASK_ENV=development
APP_HOST=0.0.0.0
COLLECTOR_API_INTERNAL_PORT=4000
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-jwt
JWT_EXPIRATION_HOURS=24
AUTH_REQUIRED=false
ROOT_CORS_ORIGINS=http://localhost,https://localhost
COLLECTOR_CORS_ORIGINS=*

ROOT_DATABASE_URL=postgresql+psycopg2://tratamiento:tratamiento@postgres:5432/tratamiento_audio
COLLECTOR_DATABASE_URL=postgresql://tratamiento:tratamiento@postgres:5432/tratamiento_audio
PROCESSOR_DATABASE_URL=postgresql://tratamiento:tratamiento@postgres:5432/tratamiento_audio
POSTGRES_SSLMODE=disable

REDIS_URL=redis://redis:6379/0
REDIS_BLOCK_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO

COLLECTOR_FRONTEND_BASE_HREF=/collector/
NG_APP_URL_COLLECTOR_API=/collector-api
NG_APP_API_URL=
