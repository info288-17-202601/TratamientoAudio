FLASK_ENV=development
APP_HOST=0.0.0.0
APP_PORT=5000
SECRET_KEY=change-me

# SQLite local por defecto si DATABASE_URL queda vacio.
DATABASE_URL=sqlite:///database.db

SUPABASE_URL=
SUPABASE_KEY=

AUTH_REQUIRED=false
CORS_ORIGINS=*

# Redis push queue used to enqueue audio processing jobs. Example value:
# redis://default:helOqvYvOO8Ldrb5GiLdQ0Dni9AIrlnI@observing-sleek-son-32324.db.redis.io:1784
REDIS_URL=
# Name of the Redis list/queue where messages will be pushed
REDIS_QUEUE=audio_jobs
